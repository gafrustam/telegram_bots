[Unit]
Description=Monopoly Mini App FastAPI Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/telegram_bots/monopoly_bot
ExecStart=/home/ubuntu/telegram_bots/monopoly_bot/venv/bin/uvicorn server:app --host 127.0.0.1 --port 8003 --log-level info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
